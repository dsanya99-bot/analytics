# ─── Сервер ───────────────────────────────────────────────
PORT=4100
NODE_ENV=development

# ─── Доступ в кабинет (общий пароль, без личных аккаунтов) ──
# Вариант 1 (рекомендуется для прод): scrypt-хеш пароля.
#   Сгенерировать:  npm run hash -- "ваш-длинный-пароль"
#   Затем вставить сюда результат:
ADMIN_PASSWORD_HASH=
# Вариант 2 (только для локальной разработки): пароль в открытом виде.
#   Используется, если ADMIN_PASSWORD_HASH пуст. В прод НЕ применять.
ADMIN_PASSWORD=changeme123

# ─── Секрет для подписи сессионных токенов (JWT-mini, HMAC-SHA256) ──
# Сгенерировать:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Срок жизни сессии в часах
SESSION_TTL_HOURS=12

# ─── База данных (SQLite) ──────────────────────────────────
# ВАЖНО: не держите файл БД внутри папки OneDrive/Dropbox — синхронизация
# лочит .db-wal и может повредить базу. По умолчанию кладём в домашнюю папку
# вне облака. Можно указать любой абсолютный путь вне синхронизируемых папок.
DB_PATH=

# ─── Лимит попыток входа (anti-bruteforce) ─────────────────
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_MINUTES=10
